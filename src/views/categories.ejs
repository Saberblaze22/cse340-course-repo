<%- include('partials/header') %>

<main>
    <h1><%= title %></h1>
    <h2>Upcoming Service Projects</h2>

    <ul>
        <% categories.forEach(category => { %>
            <li>
                <a href="/category/<%= category.category_id %>">
                    <%= category.name %>
                </a>

                <!-- ADMIN ONLY: Edit category -->
                <% if (user && user.role_name === 'admin') { %>
                    | <a href="/edit-category/<%= category.category_id %>">
                        Edit
                    </a>
                <% } %>
            </li>
        <% }) %>
    </ul>

    <% if (user && user.role_name === 'admin') { %>
        <p>
            <a href="/new-category">Add New Category</a>
        </p>
    <% } %>

</main>

<%- include('partials/footer') %>